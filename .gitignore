# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# Environment
.env
.env.local
.env.*.local

# Local dev overrides — generated by local_dev/setup-local.py, never committed
local_dev/.env
projects/*/web/config.js
projects/*/app/.env

# Node / Expo
node_modules/
.expo/
dist/
build/
*.log
npm-debug.log*
package-lock.json
# Native apps need a committed lock file so EAS Build / expo-doctor can run.
!projects/*/app/package-lock.json

# Web prototypes copy ../shared/ into web/shared/ at build time (see web/build.sh).
# The source of truth lives in projects/<name>/shared/.
projects/*/web/shared/

# Database
*.sqlite
*.sqlite3
*.db

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Claude Code
.claude/settings.local.json

# Vercel
.vercel/

# Railway
.railway/

# EAS / Play Store credentials — contains private keys that must not be committed.
play-service-account.json
*.keystore
*.jks
