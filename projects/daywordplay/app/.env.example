# Day Word Play — Expo env vars. Copy to .env and fill in.
#
# All vars are baked into the JS bundle at build time, so keep this in sync
# with the Railway backend + Supabase project for the matching webUrl entry
# in /landing/registry.json.

EXPO_PUBLIC_API_URL=https://vibelab-production-2119.up.railway.app
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Web bridge that hands OAuth redirects back to the native app. Default points
# at the Vercel-hosted daywordplay web prototype's /auth-callback.html.
EXPO_PUBLIC_AUTH_CALLBACK_URL=https://vibelab-daywordplay.vercel.app/auth-callback.html
