# API client default already points at Railway production; only set this to
# override (e.g. point at a local backend on your LAN).
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000

# Supabase email auth (Phase 2). With both set, the home screen shows a
# Sign-in pill, sauces get a heart, and Settings unlocks. With either blank,
# the app stays read-only.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
