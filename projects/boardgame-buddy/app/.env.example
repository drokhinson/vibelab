# BoardgameBuddy native app — local env. Copy to .env and fill in.
# These EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.

# Shared Railway FastAPI backend (no trailing slash).
EXPO_PUBLIC_API_URL=https://vibelab-production-2119.up.railway.app

# Supabase (same shared vibelab project the web app uses).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OAuth bridge page hosted on the BGB Vercel deploy. Override only if the
# web app moves hosts. Defaults to the BGB production deploy in oauth.js.
EXPO_PUBLIC_AUTH_CALLBACK_URL=https://vibelab-boardgamebuddy.vercel.app/auth-callback.html
