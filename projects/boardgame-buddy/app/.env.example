# Boardgame Buddy native app — local dev config.
# Copy to .env and fill in. All vars are EXPO_PUBLIC_* so they're bundled
# into the JS at build time (no secrets here — the anon key is public-safe).

# Shared Railway backend base URL (no trailing slash).
EXPO_PUBLIC_API_URL=http://localhost:8000

# Supabase project (shared across vibelab apps).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Hosted OAuth bridge page on the BoardgameBuddy web deploy. Google sign-in
# routes through this https page, which forwards the auth code to the native
# deep link. Must be allowlisted in Supabase → Auth → URL Configuration.
EXPO_PUBLIC_AUTH_CALLBACK_URL=https://boardgame-buddy.vercel.app/auth-callback.html
