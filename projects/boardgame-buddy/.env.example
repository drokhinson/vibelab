# Web prototype config
# Copy to projects/boardgame-buddy/web/config.js and update the apiBase URL
# VITE_API_BASE=https://your-backend.railway.app

# BoardGameGeek API token — register at boardgamegeek.com/applications to obtain one
# Set BGG_API_TOKEN in Railway environment variables (backend reads it via os.getenv)
BGG_API_TOKEN=your_bgg_bearer_token_here

# React Native / Expo
# Copy to projects/boardgame-buddy/app/.env
EXPO_PUBLIC_API_URL=http://localhost:8000

# Supabase (for direct client-side access, if needed)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
