# Supabase — ONE shared project for all vibelab apps
    # NOTE: https://<project-ref>.supabase.co (no trailing / or /rest/v1)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Anon key is NOT used by the backend, but local_dev/setup-local.py reads it from here
# so it can write config.js and app/.env for every project in one step.
SUPABASE_ANON_KEY=your-anon-key

# CORS — comma-separated list of allowed origins (no trailing slash)
# Include Vercel URLs for each project's web frontend + localhost for dev
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
